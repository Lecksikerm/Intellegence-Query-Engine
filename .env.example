PORT=5000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
NODE_ENV=production

# Use long random values in production
ACCESS_TOKEN_SECRET=replace-with-long-random-access-secret
REFRESH_TOKEN_SECRET=replace-with-long-random-refresh-secret

# Optional overrides (defaults are 5m and 30m)
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30m

# Frontend origins (comma-separated)
FRONTEND_URL=https://your-web-portal-domain.com
WEB_PORTAL_URL=https://your-web-portal-domain.com
CORS_ORIGINS=https://your-web-portal-domain.com

# GitHub OAuth
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret
GITHUB_CALLBACK_URL=https://your-backend-domain.up.railway.app/api/auth/github/callback
